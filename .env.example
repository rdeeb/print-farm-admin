# Database
DATABASE_URL="postgresql://farm_user:farm_password@localhost:5432/farm_admin?schema=public"

# NextAuth.js
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# JWT
JWT_SECRET="your-jwt-secret-here"

# Redis (for caching and SSE)
REDIS_URL="redis://localhost:6379"

# Email (optional, for notifications)
EMAIL_FROM=""
EMAIL_HOST=""
EMAIL_PORT=""
EMAIL_USER=""
EMAIL_PASSWORD=""

# App Configuration
APP_NAME="3D Farm Admin"
APP_URL="http://localhost:3000"

# File Upload (optional)
MAX_FILE_SIZE=10485760 # 10MB
UPLOAD_PATH="./uploads"

# Feature flags
# Set to "true" to show Sign In / Register links and allow new account creation.
# Set to "false" (or leave unset) to hide auth links (pre-launch mode).
NEXT_PUBLIC_REGISTRATION_ENABLED=false

# Stripe (required for subscription billing)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_SOLO_MONTHLY=price_xxx
STRIPE_PRICE_SOLO_ANNUAL=price_xxx
STRIPE_PRICE_SHOP_MONTHLY=price_xxx
STRIPE_PRICE_SHOP_ANNUAL=price_xxx
STRIPE_PRICE_FARM_MONTHLY=price_xxx
STRIPE_PRICE_FARM_ANNUAL=price_xxx

# Connector crypto (for printer connector auth)
CONNECTOR_ENCRYPTION_KEY=your-32-byte-hex-key-here
